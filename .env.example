# ============================================================
# API Key 配置模板
#
# 使用步骤：
#   1. 复制本文件：cp .env.example .env（Windows: copy .env.example .env）
#   2. 编辑 .env，把 your_xxx_key_here 替换成你的真实 Key
#   3. .env 已在 .gitignore 中，不会被提交到 Git
#
# VSCode 会自动加载 .env 文件，运行 .py 文件时无需手动设置环境变量。
# ============================================================

# ── DeepSeek API Key ─────────────────────────────────────────
# 获取地址：https://platform.deepseek.com/api_keys
# 用途：LangChain03/、LangGraph08/、Translator04/、memory05/ 等使用 DeepSeek 的模块
DEEPSEEK_API_KEY=your_deepseek_key_here

# ── OpenAI API Key ───────────────────────────────────────────
# 获取地址：https://platform.openai.com/api-keys
# 用途：open ai 02/ 目录下的 demo
OPENAI_API_KEY=your_openai_key_here

# ── 可选：自定义 API Base URL ────────────────────────────────
# 如果使用中转服务或本地部署，取消注释并修改
# OPENAI_BASE_URL=https://api.openai.com/v1
# DEEPSEEK_BASE_URL=https://api.deepseek.com
